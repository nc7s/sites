extends base.template.pug

block head_end
	link(rel='stylesheet' href='/page.css')
	link(rel='stylesheet' href='/ji.css')
	link(rel='alternate' type='application/atom+xml' title='寄己集' href='/ji/feed.xml')
	title 寄己集

block body
	.ji-layout
		header
			h1
				ruby 寄
					rt jì
				ruby 己
					rt jǐ
				ruby 集
					rt jí
		main
			-
				const groups = []
				let currentGroup = null
				for(const entry of entries) {
					const d = new Date(entry.date || entry.created)
					const year = d.getFullYear()
					if(!currentGroup || currentGroup.year !== year) {
						currentGroup = { year, entries: [] }
						groups.push(currentGroup)
					}
					currentGroup.entries.push({ ...entry, _date: d })
				}
			each group in groups
				section.year-group
					span.year= chineseYear(new Date(group.year, 0))
					= ' '
					-
						let lastMonth = null
					each entry in group.entries
						-
							const month = entry._date.getMonth()
						if month !== lastMonth
							span.month= chineseMonth(entry._date)
							= ' '
							- lastMonth = month
						span.entry
							span.day= entry._date.getDate()
							= ' '
							a(href=entry.path)= entry.title
							= ' '
			include footer.template.pug
